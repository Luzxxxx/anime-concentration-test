  "private": true,
  "description": "一款包含 226 道题、角色画像与个性化通行证的 ACGN 知识测试 PWA",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "homepage": "https://luzxxxx.github.io/anime-concentration-test/",
  "repository": {
    "type": "git",
